# ============================================
# HireMind AI — Environment Configuration
# ============================================
# Copy this to .env and fill in your values

# ── Application ────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=false

# ── AI Provider ────────────────────────────
# Options: "groq" | "openai" | "gemini" | "claude" | "mock"
AI_PROVIDER=groq

# Groq
GROQ_API_KEY=gsk_your-groq-key-here

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# Google Gemini
GEMINI_API_KEY=your-gemini-key-here

# Anthropic Claude
ANTHROPIC_API_KEY=your-claude-key-here

# ── Databases ──────────────────────────────
# SQLite (default for local dev)
DATABASE_URL=sqlite+aiosqlite:///./hiremind.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql+asyncpg://hiremind:password@localhost:5432/hiremind

REDIS_URL=redis://localhost:6379

# ── Vector Database ────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=candidate_embeddings

# ── Graph Database ─────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=hiremind123

# ── Auth ───────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Google OAuth ───────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── File Upload ────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ── Embedding Model ────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Frontend ───────────────────────────────
VITE_API_URL=http://localhost:8000

# ── Clerk Auth ─────────────────────────────
CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
