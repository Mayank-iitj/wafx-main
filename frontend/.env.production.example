# Production environment — set these as Vercel Project Environment Variables
# DO NOT commit real values — use the Vercel dashboard or `vercel env add`

# Your deployed backend URL (Railway / Fly.io / Render / AWS)
NEXT_PUBLIC_API_URL=https://your-backend.railway.app/api/v1

# WebSocket URL for real-time alerts
# On Railway/Render the same host is used, just change https → wss
NEXT_PUBLIC_WS_URL=wss://your-backend.railway.app/api/v1
